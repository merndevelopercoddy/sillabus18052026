{{> superadmin_sidebar}}
<div id="content-wrapper" class="d-flex flex-column">
  <div id="content">
    {{> navbar}}
    <div class="container-fluid">

      <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Superadmin Dashboard</h1>
      </div>

      {{!-- Statistika kartalar --}}
      <div class="row">
        <div class="col-xl-3 col-md-6 mb-4">
          <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">
              <div class="row no-gutters align-items-center">
                <div class="col mr-2">
                  <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Kafedralar</div>
                  <div class="h5 mb-0 font-weight-bold text-gray-800">{{kafedraCount}}</div>
                </div>
                <div class="col-auto"><i class="fas fa-university fa-2x text-gray-300"></i></div>
              </div>
            </div>
          </div>
        </div>

        {{#each userStats}}
        <div class="col-xl-3 col-md-6 mb-4">
          <div class="card border-left-info shadow h-100 py-2">
            <div class="card-body">
              <div class="row no-gutters align-items-center">
                <div class="col mr-2">
                  <div class="text-xs font-weight-bold text-info text-uppercase mb-1">{{this.role}}</div>
                  <div class="h5 mb-0 font-weight-bold text-gray-800">{{this.count}} ta</div>
                </div>
                <div class="col-auto"><i class="fas fa-user fa-2x text-gray-300"></i></div>
              </div>
            </div>
          </div>
        </div>
        {{/each}}
      </div>

      {{!-- Faol akademik yil --}}
      <div class="row">
        <div class="col-lg-6 mb-4">
          <div class="card shadow">
            <div class="card-header py-3">
              <h6 class="m-0 font-weight-bold text-primary">Faol akademik yil</h6>
            </div>
            <div class="card-body">
              {{#if faolYil}}
              <h4 class="text-success font-weight-bold">{{faolYil.nomi}}</h4>
              <p class="text-muted mb-0">{{faolYil.boshlanish_yil}} — {{faolYil.tugash_yil}} o'quv yili faol holda.</p>
              {{else}}
              <p class="text-danger">Faol akademik yil belgilanmagan.</p>
              <a href="/superadmin/akademik-yillar" class="btn btn-sm btn-warning">Belgilash</a>
              {{/if}}
            </div>
          </div>
        </div>

        <div class="col-lg-6 mb-4">
          <div class="card shadow">
            <div class="card-header py-3">
              <h6 class="m-0 font-weight-bold text-primary">Tezkor havolalar</h6>
            </div>
            <div class="card-body">
              <a href="/superadmin/users" class="btn btn-primary btn-sm mb-2 mr-2"><i class="fas fa-users mr-1"></i>Foydalanuvchilar</a>
              <a href="/superadmin/kafedralar" class="btn btn-success btn-sm mb-2 mr-2"><i class="fas fa-university mr-1"></i>Kafedralar</a>
              <a href="/superadmin/akademik-yillar" class="btn btn-info btn-sm mb-2"><i class="fas fa-calendar-alt mr-1"></i>Akademik yillar</a>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
  <footer class="sticky-footer bg-white">
    <div class="container my-auto">
      <div class="copyright text-center my-auto">
        <span>Barcha huquqlar himoyalangan &copy; 2026</span>
      </div>
    </div>
  </footer>
</div>
