{{> manager_sidebar}}
<div id="content-wrapper" class="d-flex flex-column">
    <div id="content">
        {{> navbar}}

        <div class="container my-4">
            <div class="row">
                <div class="col-lg-8 shadow-lg px-5 py-4 mb-5 bg-body rounded offset-md-2">

                    {{#if success.[0]}}
                    <div class="alert alert-success" role="alert">
                        {{success.[0]}}
                    </div>
                    {{/if}}

                    {{#if error.[0]}}
                    <div class="alert alert-danger" role="alert">
                        {{error.[0]}}
                    </div>
                    {{/if}}

                    <h3 class="text-center mb-4">Ta'lim yo'nalishini tahrirlash</h3>

                    <form method="POST" action="/manager/yonalish/{{item.id}}/edit">
                        <div class="mb-3">
                            <label for="yonalish_shifri" class="form-label">Ta'lim yo'nalishi shifri</label>
                            <input
                                type="text"
                                class="form-control"
                                id="yonalish_shifri"
                                name="yonalish_shifri"
                                value="{{item.yonalish_shifri}}"
                                required
                            >
                        </div>

                        <div class="mb-3">
                            <label for="yonalish_nomi" class="form-label">Yo'nalish nomi</label>
                            <input
                                type="text"
                                class="form-control"
                                id="yonalish_nomi"
                                name="yonalish_nomi"
                                value="{{item.yonalish_nomi}}"
                                required
                            >
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="/manager/yonalish" class="btn btn-secondary">Orqaga</a>
                            <button type="submit" class="btn btn-primary">Yangilash</button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>

    <footer class="sticky-footer bg-white">
        <div class="container my-auto">
            <div class="copyright text-center my-auto">
                <span>Barcha huquqlar himoyalangan &copy; 2026</span>
            </div>
        </div>
    </footer>
</div>