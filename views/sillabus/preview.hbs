{{> oqituvchi_sidebar}}
<div id="content-wrapper" class="d-flex flex-column">
  <div id="content">
    {{> navbar}}
    <div class="container-fluid">

      {{!-- Amallar paneli --}}
      <div class="d-flex flex-column flex-md-row justify-content-between align-items-stretch align-items-md-center mb-3 no-print">
        <div class="mb-2 mb-md-0">
          <a href="{{urlPrefix}}/sillabuslar/{{sillabus.id}}" class="btn btn-sm btn-outline-secondary mr-2">
            <i class="fas fa-arrow-left mr-1"></i>Orqaga
          </a>
        </div>
        <div class="d-flex flex-wrap align-items-center">
          {{#if (eq sillabus.holat "tasdiqlangan")}}
            <span class="badge badge-success p-2 mr-2 mb-2"><i class="fas fa-check-circle mr-1"></i>Tasdiqlangan</span>
          {{else if (eq sillabus.holat "yuborilgan")}}
            <span class="badge badge-warning p-2 mr-2 mb-2"><i class="fas fa-clock mr-1"></i>Tasdiqlash kutilmoqda</span>
          {{/if}}
          <a href="{{urlPrefix}}/sillabuslar/{{sillabus.id}}/word"
             class="btn btn-sm btn-outline-primary mr-2 mb-2">
            <i class="fas fa-file-word mr-1"></i>Word yuklab olish
          </a>
          {{#unless (eq sillabus.holat "tasdiqlangan")}}
          {{#unless (eq sillabus.holat "yuborilgan")}}
          <form action="{{urlPrefix}}/sillabuslar/{{sillabus.id}}/yuborish" method="POST" style="display:inline;" class="mb-2">
            <button type="submit" class="btn btn-sm btn-success"
              onclick="return confirm('Sillabusni tasdiqlashga yuborishni tasdiqlaysizmi?')">
              <i class="fas fa-paper-plane mr-1"></i>Tasdiqlashga yuborish
            </button>
          </form>
          {{/unless}}
          {{/unless}}
        </div>
      </div>

      {{#if success.[0]}}<div class="alert alert-success no-print">{{success.[0]}}</div>{{/if}}
      {{#if error.[0]}}<div class="alert alert-danger no-print">{{error.[0]}}</div>{{/if}}

      <style>
        @media print {
          .no-print { display: none !important; }
          .sillabus-page-break { break-before: page; page-break-before: always; }
        }
        .sillabus-doc-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
        .sillabus-doc { font-family: 'Times New Roman', serif; font-size: 13px; line-height: 1.35; zoom: 1.75; width: 70%; margin: 0 auto; }
        .sillabus-doc table { border-collapse: collapse; }
        .sillabus-doc h5 { text-align: center; font-weight: bold; margin: 16px 0 8px; font-size: 13px; }
        @media (max-width: 768px) {
          .sillabus-doc { width: 700px; max-width: none; zoom: 1; margin: 0; }
        }
        .inline-editable { outline: none; border-bottom: 1px dashed transparent; cursor: text; border-radius: 2px; }
        .inline-editable:hover { border-bottom-color: #aaa; }
        .inline-editable:focus { border-bottom-color: #1a4f91; background: #fffde7; }
        .inline-editable:empty:before { content: attr(data-placeholder); color: #aaa; font-style: italic; }
        .inline-editable.ie-saving { opacity: 0.5; }
        .inline-editable.ie-saved { background: #d4edda; transition: background 1.2s ease; }
        .inline-editable.ie-error { background: #f8d7da; }
        .adabiyot-suggest-list {
          display: none; position: absolute; top: 100%; left: 0; right: 0; z-index: 20;
          background: #fff; border: 1px solid #ccc; border-radius: 4px; box-shadow: 0 4px 12px rgba(0,0,0,.15);
          max-height: 220px; overflow-y: auto; font-family: -apple-system, sans-serif; font-size: 12px;
        }
        .adabiyot-suggest-list.show { display: block; }
        .adabiyot-suggest-title { padding: 6px 10px 2px; color: #888; font-size: 11px; }
        .adabiyot-suggest-item { padding: 6px 10px; cursor: pointer; color: #1a4f91; border-top: 1px solid #f0f0f0; }
        .adabiyot-suggest-item:hover { background: #f4f8ff; }
        [data-inline-edit-panel].ie-panel-saving { opacity: 0.6; transition: opacity 0.15s; }
        .doc-input {
          width: 100%; border: none; background: transparent; font: inherit; color: inherit;
          padding: 0; resize: none; outline: none; display: block;
        }
        .doc-input:focus { background: #fffde7; outline: 1px dashed #1a4f91; }
        .doc-input::placeholder { color: #bbb; font-style: italic; }
        .doc-autogrow { overflow: hidden; white-space: pre-wrap; word-wrap: break-word; word-break: break-word; }
        .doc-del-btn { border: none; background: transparent; color: #c00; font-size: 15px; line-height: 1; cursor: pointer; padding: 0 4px; }
        .doc-new-row { color: #999; }
      </style>

      {{!-- RASMIY HUJJAT --}}
      <div class="sillabus-doc-wrap">
      <div class="bg-white shadow p-4 mb-4 sillabus-doc" {{#if showInlineEdit}}data-save-url="{{urlPrefix}}/sillabuslar/{{sillabus.id}}/umumiy-field"{{/if}}>{{> sillabus_document}}</div>{{!-- /hujjat --}}
      </div>{{!-- /sillabus-doc-wrap --}}

      {{#if showInlineEdit}}
      <script src="/js/sillabus-autogrow.js"></script>
      <script src="/js/sillabus-inline-edit.js"></script>
      <script src="/js/sillabus-contenteditable.js"></script>
      {{/if}}
    </div>
  </div>
  <footer class="sticky-footer bg-white">
    <div class="container my-auto">
      <div class="copyright text-center my-auto">
        <span>Barcha huquqlar himoyalangan &copy; 2026</span>
      </div>
    </div>
  </footer>
</div>
