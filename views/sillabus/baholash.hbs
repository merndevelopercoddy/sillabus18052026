{{#if isOqituvchi}}
  {{> oqituvchi_sidebar}}
{{else}}
  {{> oquv_bolimi_sidebar}}
{{/if}}
<div id="content-wrapper" class="d-flex flex-column">
  <div id="content">
    {{> navbar}}
    <div class="container-fluid">

      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <a href="{{#if isOqituvchi}}/oqituvchi/sillabuslar/{{sillabus.id}}{{else}}/oquv-bolimi/sillabuslar/{{sillabus.id}}/umumiy{{/if}}" class="btn btn-sm btn-outline-secondary mr-2">
            <i class="fas fa-arrow-left mr-1"></i>Orqaga
          </a>
          <h1 class="h3 d-inline mb-0 text-gray-800">Baholash mezoni va rejasi</h1>
        </div>
        <span class="badge badge-warning p-2">{{sillabus.f_nomi}}</span>
      </div>

      {{!-- ===== BAHOLASH MEZONI (FOIZ) ===== --}}
      <div class="card shadow mb-2 {{#if editMezoni}}border-left-warning{{else}}border-left-warning{{/if}}">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
          <h6 class="m-0 font-weight-bold text-warning">
            {{#if editMezoni}}<i class="fas fa-edit mr-1"></i>Foiz yozuvini tahrirlash{{else}}<i class="fas fa-percentage mr-1"></i>Fanni baholash mezoni (foiz jadval){{/if}}
          </h6>
          {{#if editMezoni}}
          <a href="{{urlPrefix}}/sillabuslar/{{sillabus.id}}/baholash" class="btn btn-sm btn-outline-secondary">
            <i class="fas fa-times mr-1"></i>Bekor qilish
          </a>
          {{/if}}
        </div>
        <div class="card-body">
          {{#if editMezoni}}
          <form method="POST" action="{{urlPrefix}}/sillabuslar/{{sillabus.id}}/baholash/mezoni/{{editMezoni.id}}/update" class="mb-0">
          {{else}}
          <form method="POST" action="{{urlPrefix}}/sillabuslar/{{sillabus.id}}/baholash/mezoni/add" class="mb-0">
          {{/if}}
            <div class="row">
              <div class="col-md-4">
                <div class="form-group mb-0">
                  <input type="text" name="nomi" class="form-control form-control-sm"
                    placeholder="Baholash turi (masalan: Davomat)"
                    value="{{#if editMezoni}}{{editMezoni.nomi}}{{/if}}" required>
                </div>
              </div>
              <div class="col-md-2">
                <div class="form-group mb-0">
                  <div class="input-group input-group-sm">
                    <input type="number" name="foiz" class="form-control form-control-sm"
                      placeholder="Foiz" min="0" max="100" step="0.01"
                      value="{{#if editMezoni}}{{editMezoni.foiz}}{{/if}}" required>
                    <div class="input-group-append"><span class="input-group-text">%</span></div>
                  </div>
                </div>
              </div>
              <div class="col-md-3">
                <div class="form-group mb-0">
                  <input type="text" name="izoh" class="form-control form-control-sm"
                    placeholder="Izoh (ixtiyoriy)"
                    value="{{#if editMezoni}}{{editMezoni.izoh}}{{/if}}">
                </div>
              </div>
              <div class="col-md-1">
                <div class="form-group mb-0">
                  <input type="number" name="tartib" class="form-control form-control-sm"
                    placeholder="Tartib" min="0"
                    value="{{#if editMezoni}}{{editMezoni.tartib}}{{else}}0{{/if}}">
                </div>
              </div>
              <div class="col-md-2">
                <button type="submit" class="btn btn-sm {{#if editMezoni}}btn-warning{{else}}btn-warning{{/if}} w-100">
                  <i class="fas {{#if editMezoni}}fa-save{{else}}fa-plus{{/if}} mr-1"></i>
                  {{#if editMezoni}}Saqlash{{else}}Qo'shish{{/if}}
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>

      {{#if mezoniRows.length}}
      <div class="card shadow mb-4">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-bordered table-sm mb-0">
              <thead class="thead-light">
                <tr>
                  <th>Baholash turi</th>
                  <th class="text-center" style="width:100px">Foiz</th>
                  <th>Izoh</th>
                  <th class="text-center" style="width:110px">Amallar</th>
                </tr>
              </thead>
              <tbody>
                {{#each mezoniRows}}
                <tr class="{{#if (eq this.id ../editMezoni.id)}}table-warning{{/if}}">
                  <td>{{this.nomi}}</td>
                  <td class="text-center"><span class="badge badge-warning">{{this.foiz}}%</span></td>
                  <td>{{#if this.izoh}}{{this.izoh}}{{else}}<span class="text-muted">—</span>{{/if}}</td>
                  <td class="text-center">
                    <a href="{{../urlPrefix}}/sillabuslar/{{../sillabus.id}}/baholash?editMezoni={{this.id}}"
                       class="btn btn-warning btn-sm mr-1" title="Tahrirlash">
                      <i class="fas fa-edit"></i>
                    </a>
                    <form method="POST" action="{{../urlPrefix}}/sillabuslar/{{../sillabus.id}}/baholash/mezoni/{{this.id}}/delete"
                          class="d-inline" onsubmit="return confirm('O\'chirishni tasdiqlaysizmi?')">
                      <button type="submit" class="btn btn-danger btn-sm">
                        <i class="fas fa-trash"></i>
                      </button>
                    </form>
                  </td>
                </tr>
                {{/each}}
              </tbody>
              <tfoot class="thead-light">
                <tr>
                  <th class="text-right">Jami:</th>
                  <th class="text-center font-weight-bold {{#if (gt (totalFoiz mezoniRows) 100)}}text-danger{{else}}text-success{{/if}}">
                    {{totalFoiz mezoniRows}}%
                  </th>
                  <th colspan="2">
                    {{#if (gt (totalFoiz mezoniRows) 100)}}
                    <small class="text-danger"><i class="fas fa-exclamation-triangle mr-1"></i>Jami 100% dan oshib ketdi!</small>
                    {{/if}}
                  </th>
                </tr>
              </tfoot>
            </table>
          </div>
        </div>
      </div>
      {{else}}
      <div class="alert alert-light border mb-4">
        <i class="fas fa-inbox mr-1"></i> Hali baholash mezonlari qo'shilmagan
      </div>
      {{/if}}

      {{!-- ===== TALABALAR BAHOLASH (BALL) ===== --}}
      <div class="card shadow mb-2">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
          <h6 class="m-0 font-weight-bold text-info">
            {{#if editTalabalar}}<i class="fas fa-edit mr-1"></i>Ball yozuvini tahrirlash{{else}}<i class="fas fa-star mr-1"></i>Talabalar bilimini baholash mezoni (ball jadval){{/if}}
          </h6>
          {{#if editTalabalar}}
          <a href="{{urlPrefix}}/sillabuslar/{{sillabus.id}}/baholash" class="btn btn-sm btn-outline-secondary">
            <i class="fas fa-times mr-1"></i>Bekor qilish
          </a>
          {{/if}}
        </div>
        <div class="card-body">
          {{#if editTalabalar}}
          <form method="POST" action="{{urlPrefix}}/sillabuslar/{{sillabus.id}}/baholash/talabalar/{{editTalabalar.id}}/update" class="mb-0">
          {{else}}
          <form method="POST" action="{{urlPrefix}}/sillabuslar/{{sillabus.id}}/baholash/talabalar/add" class="mb-0">
          {{/if}}
            <div class="row">
              <div class="col-md-2">
                <div class="form-group mb-0">
                  <input type="text" name="guruh" class="form-control form-control-sm"
                    placeholder="Guruh (masalan: DV)"
                    value="{{#if editTalabalar}}{{editTalabalar.guruh}}{{/if}}" required>
                </div>
              </div>
              <div class="col-md-3">
                <div class="form-group mb-0">
                  <input type="text" name="nazorat_nomi" class="form-control form-control-sm"
                    placeholder="Nazorat nomi"
                    value="{{#if editTalabalar}}{{editTalabalar.nazorat_nomi}}{{/if}}" required>
                </div>
              </div>
              <div class="col-md-2">
                <div class="form-group mb-0">
                  <input type="text" name="izoh" class="form-control form-control-sm"
                    placeholder="Izoh"
                    value="{{#if editTalabalar}}{{editTalabalar.izoh}}{{/if}}">
                </div>
              </div>
              <div class="col-md-1">
                <div class="form-group mb-0">
                  <input type="number" name="ball" class="form-control form-control-sm"
                    placeholder="Ball" min="0"
                    value="{{#if editTalabalar}}{{editTalabalar.ball}}{{/if}}" required>
                </div>
              </div>
              <div class="col-md-2">
                <div class="form-group mb-0">
                  <input type="text" name="otkazilish_vaqti" class="form-control form-control-sm"
                    placeholder="O'tkazish vaqti"
                    value="{{#if editTalabalar}}{{editTalabalar.otkazilish_vaqti}}{{/if}}">
                </div>
              </div>
              <div class="col-md-2">
                <button type="submit" class="btn btn-sm btn-info w-100">
                  <i class="fas {{#if editTalabalar}}fa-save{{else}}fa-plus{{/if}} mr-1"></i>
                  {{#if editTalabalar}}Saqlash{{else}}Qo'shish{{/if}}
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>

      {{#if talabalarRows.length}}
      <div class="card shadow mb-4">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-bordered table-sm mb-0">
              <thead class="thead-light">
                <tr>
                  <th>Guruh</th>
                  <th>Nazorat nomi</th>
                  <th>Izoh</th>
                  <th class="text-center" style="width:80px">Ball</th>
                  <th>O'tkazish vaqti</th>
                  <th class="text-center" style="width:110px">Amallar</th>
                </tr>
              </thead>
              <tbody>
                {{#each talabalarRows}}
                <tr class="{{#if (eq this.id ../editTalabalar.id)}}table-info{{/if}}">
                  <td><span class="badge badge-secondary">{{this.guruh}}</span></td>
                  <td>{{this.nazorat_nomi}}</td>
                  <td>{{#if this.izoh}}{{this.izoh}}{{else}}<span class="text-muted">—</span>{{/if}}</td>
                  <td class="text-center"><span class="badge badge-info">{{this.ball}}</span></td>
                  <td>{{#if this.otkazilish_vaqti}}{{this.otkazilish_vaqti}}{{else}}<span class="text-muted">—</span>{{/if}}</td>
                  <td class="text-center">
                    <a href="{{../urlPrefix}}/sillabuslar/{{../sillabus.id}}/baholash?editTalabalar={{this.id}}"
                       class="btn btn-info btn-sm mr-1" title="Tahrirlash">
                      <i class="fas fa-edit"></i>
                    </a>
                    <form method="POST" action="{{../urlPrefix}}/sillabuslar/{{../sillabus.id}}/baholash/talabalar/{{this.id}}/delete"
                          class="d-inline" onsubmit="return confirm('O\'chirishni tasdiqlaysizmi?')">
                      <button type="submit" class="btn btn-danger btn-sm">
                        <i class="fas fa-trash"></i>
                      </button>
                    </form>
                  </td>
                </tr>
                {{/each}}
              </tbody>
              <tfoot class="thead-light">
                <tr>
                  <th colspan="3" class="text-right">Jami ball:</th>
                  <th class="text-center font-weight-bold {{#if (gt (totalBall talabalarRows) 100)}}text-danger{{else}}text-info{{/if}}">
                    {{totalBall talabalarRows}}
                  </th>
                  <th colspan="2">
                    {{#if (gt (totalBall talabalarRows) 100)}}
                    <small class="text-danger"><i class="fas fa-exclamation-triangle mr-1"></i>Jami 100 balldan oshdi!</small>
                    {{/if}}
                  </th>
                </tr>
              </tfoot>
            </table>
          </div>
        </div>
      </div>
      {{else}}
      <div class="alert alert-light border mb-4">
        <i class="fas fa-inbox mr-1"></i> Hali baholash yozuvlari qo'shilmagan
      </div>
      {{/if}}

    </div>
  </div>
  <footer class="sticky-footer bg-white">
    <div class="container my-auto"><div class="copyright text-center my-auto"><span>Barcha huquqlar himoyalangan &copy; 2026</span></div></div>
  </footer>
</div>
