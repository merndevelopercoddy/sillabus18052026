{{#if isOqituvchi}}
  {{> oqituvchi_sidebar}}
{{else}}
  {{> oquv_bolimi_sidebar}}
{{/if}}
<div id="content-wrapper" class="d-flex flex-column">
  <div id="content">
    {{> navbar}}
    <div class="container-fluid">

      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <a href="{{#if isOqituvchi}}/oqituvchi/sillabuslar/{{sillabus.id}}{{else}}/oquv-bolimi/sillabuslar/{{sillabus.id}}/umumiy{{/if}}" class="btn btn-sm btn-outline-secondary mr-2">
            <i class="fas fa-arrow-left mr-1"></i>Orqaga
          </a>
          <h1 class="h3 d-inline mb-0 text-gray-800">Baholash mezoni va rejasi</h1>
        </div>
        <span class="badge badge-warning p-2">{{sillabus.f_nomi}}</span>
      </div>

      {{#if error}}
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-triangle mr-1"></i> {{error}}
        <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
      </div>
      {{/if}}

      {{!-- ===== 1. FANNI BAHOLASH MEZONI (FOIZ) ===== --}}
      <div class="card shadow mb-2 border-left-warning">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
          <h6 class="m-0 font-weight-bold text-warning">
            <i class="fas fa-percentage mr-1"></i>
            {{#if editMezoni}}Foiz yozuvini tahrirlash{{else}}Fanni baholash mezoni va rejasi (foiz){{/if}}
          </h6>
          {{#if editMezoni}}
          <a href="{{urlPrefix}}/sillabuslar/{{sillabus.id}}/baholash" class="btn btn-sm btn-outline-secondary">
            <i class="fas fa-times mr-1"></i>Bekor qilish
          </a>
          {{/if}}
        </div>
        <div class="card-body">
          {{#if editMezoni}}
          <form method="POST" action="{{urlPrefix}}/sillabuslar/{{sillabus.id}}/baholash/mezoni/{{editMezoni.id}}/update" class="mb-0">
          {{else}}
          <form method="POST" action="{{urlPrefix}}/sillabuslar/{{sillabus.id}}/baholash/mezoni/add" class="mb-0">
          {{/if}}
            <div class="row align-items-end">
              <div class="col-md-1">
                <label class="small">Tartib</label>
                <input type="number" name="tartib" class="form-control form-control-sm" min="1"
                  value="{{#if editMezoni}}{{editMezoni.tartib}}{{else}}1{{/if}}">
              </div>
              <div class="col-md-4">
                <label class="small">Baholash turi <span class="text-danger">*</span></label>
                <input type="text" name="nomi" class="form-control form-control-sm"
                  placeholder="masalan: Davomat, o'z vaqtida yetib kelish"
                  value="{{#if editMezoni}}{{editMezoni.nomi}}{{/if}}" required>
              </div>
              <div class="col-md-2">
                <label class="small">Foiz <span class="text-danger">*</span></label>
                <div class="input-group input-group-sm">
                  <input type="number" name="foiz" class="form-control form-control-sm"
                    placeholder="0" min="0" max="100" step="0.01"
                    value="{{#if editMezoni}}{{editMezoni.foiz}}{{/if}}" required>
                  <div class="input-group-append"><span class="input-group-text">%</span></div>
                </div>
              </div>
              <div class="col-md-3">
                <label class="small">Izoh</label>
                <input type="text" name="izoh" class="form-control form-control-sm"
                  placeholder="Ixtiyoriy"
                  value="{{#if editMezoni}}{{editMezoni.izoh}}{{/if}}">
              </div>
              <div class="col-md-2">
                <button type="submit" class="btn btn-sm btn-warning w-100">
                  <i class="fas {{#if editMezoni}}fa-save{{else}}fa-plus{{/if}} mr-1"></i>
                  {{#if editMezoni}}Saqlash{{else}}Qo'shish{{/if}}
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>

      {{#if mezoniRows.length}}
      <div class="card shadow mb-4">
        <div class="card-body p-0">
          <table class="table table-bordered table-sm mb-0">
            <thead class="thead-light">
              <tr>
                <th style="width:40px">№</th>
                <th>Baholash turi</th>
                <th class="text-center" style="width:100px">Foiz</th>
                <th>Izoh</th>
                <th class="text-center" style="width:110px">Amallar</th>
              </tr>
            </thead>
            <tbody>
              {{#each mezoniRows}}
              <tr class="{{#if (eq this.id ../editMezoni.id)}}table-warning{{/if}}">
                <td class="text-center">{{this.tartib}}</td>
                <td>{{this.nomi}}</td>
                <td class="text-center"><span class="badge badge-warning">{{this.foiz}}%</span></td>
                <td>{{#if this.izoh}}{{this.izoh}}{{else}}<span class="text-muted">—</span>{{/if}}</td>
                <td class="text-center">
                  <a href="{{../urlPrefix}}/sillabuslar/{{../sillabus.id}}/baholash?editMezoni={{this.id}}"
                     class="btn btn-warning btn-sm mr-1" title="Tahrirlash">
                    <i class="fas fa-edit"></i>
                  </a>
                  <button type="button" class="btn btn-danger btn-sm"
                    data-toggle="modal" data-target="#delMezoni{{this.id}}">
                    <i class="fas fa-trash"></i>
                  </button>
                </td>
              </tr>
              {{/each}}
            </tbody>
            <tfoot class="thead-light">
              <tr>
                <th colspan="2" class="text-right">Jami:</th>
                <th class="text-center font-weight-bold {{#if (gt (totalFoiz mezoniRows) 100)}}text-danger{{else}}text-success{{/if}}">
                  {{totalFoiz mezoniRows}}%
                </th>
                <th colspan="2">
                  {{#if (gt (totalFoiz mezoniRows) 100)}}
                  <small class="text-danger"><i class="fas fa-exclamation-triangle mr-1"></i>100% dan oshib ketdi!</small>
                  {{/if}}
                </th>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
      {{else}}
      <div class="alert alert-light border mb-4">
        <i class="fas fa-inbox mr-1"></i> Hali baholash mezonlari qo'shilmagan
      </div>
      {{/if}}

      {{!-- ===== 2. TALABALAR BILIMINI BAHOLASH (BALL) ===== --}}
      <div class="card shadow mb-2 border-left-info">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
          <h6 class="m-0 font-weight-bold text-info">
            <i class="fas fa-star mr-1"></i>
            {{#if editTalabalar}}Ball yozuvini tahrirlash{{else}}Talabalar bilimini baholash mezoni (ball jadval){{/if}}
          </h6>
          {{#if editTalabalar}}
          <a href="{{urlPrefix}}/sillabuslar/{{sillabus.id}}/baholash" class="btn btn-sm btn-outline-secondary">
            <i class="fas fa-times mr-1"></i>Bekor qilish
          </a>
          {{/if}}
        </div>
        <div class="card-body">
          {{#if editTalabalar}}
          <form method="POST" action="{{urlPrefix}}/sillabuslar/{{sillabus.id}}/baholash/talabalar/{{editTalabalar.id}}/update" class="mb-0">
          {{else}}
          <form method="POST" action="{{urlPrefix}}/sillabuslar/{{sillabus.id}}/baholash/talabalar/add" class="mb-0">
          {{/if}}
            <div class="row align-items-end">
              <div class="col-md-1">
                <label class="small">Tartib</label>
                <input type="number" name="tartib" class="form-control form-control-sm" min="1"
                  value="{{#if editTalabalar}}{{editTalabalar.tartib}}{{else}}1{{/if}}">
              </div>
              <div class="col-md-2">
                <label class="small">Guruh <span class="text-danger">*</span></label>
                <select name="guruh" class="form-control form-control-sm" required>
                  <option value="">— tanlang —</option>
                  <option value="JB" {{#if (eq editTalabalar.guruh "JB")}}selected{{/if}}>Joriy baholash (JB)</option>
                  <option value="OI" {{#if (eq editTalabalar.guruh "OI")}}selected{{/if}}>Oraliq imtihon (OI)</option>
                  <option value="YI" {{#if (eq editTalabalar.guruh "YI")}}selected{{/if}}>Yakuniy imtihon (YI)</option>
                </select>
              </div>
              <div class="col-md-3">
                <label class="small">Nazorat nomi <span class="text-danger">*</span></label>
                <input type="text" name="nazorat_nomi" class="form-control form-control-sm"
                  placeholder="masalan: Davomat, Test"
                  value="{{#if editTalabalar}}{{editTalabalar.nazorat_nomi}}{{/if}}" required>
              </div>
              <div class="col-md-2">
                <label class="small">Izoh</label>
                <input type="text" name="izoh" class="form-control form-control-sm"
                  placeholder="Izoh"
                  value="{{#if editTalabalar}}{{editTalabalar.izoh}}{{/if}}">
              </div>
              <div class="col-md-1">
                <label class="small">Ball <span class="text-danger">*</span></label>
                <input type="number" name="ball" class="form-control form-control-sm"
                  placeholder="0" min="0"
                  value="{{#if editTalabalar}}{{editTalabalar.ball}}{{/if}}" required>
              </div>
              <div class="col-md-1">
                <label class="small">Vaqt</label>
                <input type="text" name="otkazilish_vaqti" class="form-control form-control-sm"
                  placeholder="8-hafta"
                  value="{{#if editTalabalar}}{{editTalabalar.otkazilish_vaqti}}{{/if}}">
              </div>
              <div class="col-md-2">
                <button type="submit" class="btn btn-sm btn-info w-100">
                  <i class="fas {{#if editTalabalar}}fa-save{{else}}fa-plus{{/if}} mr-1"></i>
                  {{#if editTalabalar}}Saqlash{{else}}Qo'shish{{/if}}
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>

      {{#if talabalarRows.length}}
      <div class="card shadow mb-4">
        <div class="card-body p-0">
          <table class="table table-bordered table-sm mb-0">
            <thead class="thead-light">
              <tr>
                <th style="width:40px">№</th>
                <th>Nazorat turlar</th>
                <th>Izoh</th>
                <th class="text-center" style="width:70px">Ball</th>
                <th class="text-center" style="width:120px">O'tkazilish vaqti</th>
                <th class="text-center" style="width:110px">Amallar</th>
              </tr>
            </thead>
            <tbody>
              {{#each talabalarRows}}
              <tr>
                <td class="text-center text-muted">{{this.tartib}}</td>
                <td>
                  {{#if (eq this.guruh "JB")}}<span class="badge badge-primary mr-1">JB</span>
                  {{else}}{{#if (eq this.guruh "OI")}}<span class="badge badge-success mr-1">OI</span>
                  {{else}}<span class="badge badge-warning mr-1">YI</span>
                  {{/if}}{{/if}}
                  {{this.nazorat_nomi}}
                </td>
                <td class="text-muted small">{{#if this.izoh}}{{this.izoh}}{{else}}—{{/if}}</td>
                <td class="text-center"><strong>{{this.ball}}</strong></td>
                <td class="text-center small">{{#if this.otkazilish_vaqti}}{{this.otkazilish_vaqti}}{{else}}—{{/if}}</td>
                <td class="text-center">
                  <a href="{{../urlPrefix}}/sillabuslar/{{../sillabus.id}}/baholash?editTalabalar={{this.id}}"
                     class="btn btn-info btn-sm mr-1"><i class="fas fa-edit"></i></a>
                  <button type="button" class="btn btn-danger btn-sm"
                    data-toggle="modal" data-target="#delTalabalar{{this.id}}">
                    <i class="fas fa-trash"></i>
                  </button>
                </td>
              </tr>
              {{/each}}
            </tbody>
            <tfoot class="thead-light">
              <tr>
                <th colspan="3" class="text-right">Umumiy ball:</th>
                <th class="text-center font-weight-bold {{#if (gt (totalBall talabalarRows) 100)}}text-danger{{else}}text-dark{{/if}}">
                  {{totalBall talabalarRows}}
                </th>
                <th colspan="2">
                  {{#if (gt (totalBall talabalarRows) 100)}}
                  <small class="text-danger"><i class="fas fa-exclamation-triangle mr-1"></i>100 balldan oshdi!</small>
                  {{/if}}
                </th>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
      {{else}}
      <div class="alert alert-light border mb-4">
        <i class="fas fa-inbox mr-1"></i> Hali baholash yozuvlari qo'shilmagan
      </div>
      {{/if}}

    </div>
  </div>
  <footer class="sticky-footer bg-white">
    <div class="container my-auto"><div class="copyright text-center my-auto"><span>Barcha huquqlar himoyalangan &copy; 2026</span></div></div>
  </footer>
</div>

{{!-- Mezoni o'chirish modallari --}}
{{#each mezoniRows}}
<div class="modal fade" id="delMezoni{{this.id}}" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" role="document">
    <div class="modal-content">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title"><i class="fas fa-exclamation-triangle mr-2"></i>O'chirishni tasdiqlang</h5>
        <button type="button" class="close text-white" data-dismiss="modal"><span>&times;</span></button>
      </div>
      <div class="modal-body">
        <p class="mb-2">Quyidagi baholash mezonini o'chirishga ishonchingiz komilmi?</p>
        <div class="alert alert-warning py-2 mb-0"><strong>{{this.nomi}} — {{this.foiz}}%</strong></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Bekor qilish</button>
        <form action="{{../urlPrefix}}/sillabuslar/{{../sillabus.id}}/baholash/mezoni/{{this.id}}/delete" method="POST" class="d-inline">
          <button type="submit" class="btn btn-danger"><i class="fas fa-trash mr-1"></i>O'chirish</button>
        </form>
      </div>
    </div>
  </div>
</div>
{{/each}}

{{!-- Talabalar baholash o'chirish modallari --}}
{{#each talabalarRows}}
<div class="modal fade" id="delTalabalar{{this.id}}" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" role="document">
    <div class="modal-content">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title"><i class="fas fa-exclamation-triangle mr-2"></i>O'chirishni tasdiqlang</h5>
        <button type="button" class="close text-white" data-dismiss="modal"><span>&times;</span></button>
      </div>
      <div class="modal-body">
        <p class="mb-2">Quyidagi yozuvni o'chirishga ishonchingiz komilmi?</p>
        <div class="alert alert-warning py-2 mb-0"><strong>{{this.nazorat_nomi}} — {{this.ball}} ball</strong></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Bekor qilish</button>
        <form action="{{../urlPrefix}}/sillabuslar/{{../sillabus.id}}/baholash/talabalar/{{this.id}}/delete" method="POST" class="d-inline">
          <button type="submit" class="btn btn-danger"><i class="fas fa-trash mr-1"></i>O'chirish</button>
        </form>
      </div>
    </div>
  </div>
</div>
{{/each}}
