    <tr><td style="text-align:center; font-weight:bold; vertical-align:middle;">A</td><td class="center" style="vertical-align:middle;">90-94</td><td class="center" style="vertical-align:middle;">4.0</td></tr>
    <tr><td style="text-align:center; font-weight:bold; vertical-align:middle;">B+</td><td class="center" style="vertical-align:middle;">80-89</td><td class="center" style="vertical-align:middle;">3.5</td></tr>
    <tr><td style="text-align:center; font-weight:bold; vertical-align:middle;">B</td><td class="center" style="vertical-align:middle;">70-79</td><td class="center" style="vertical-align:middle;">3.0</td></tr>
    <tr><td style="text-align:center; font-weight:bold; vertical-align:middle;">C+</td><td class="center" style="vertical-align:middle;">65-79</td><td class="center" style="vertical-align:middle;">2.5</td></tr>
    <tr><td style="text-align:center; font-weight:bold; vertical-align:middle;">C</td><td class="center" style="vertical-align:middle;">60-64</td><td class="center" style="vertical-align:middle;">2.0</td></tr>
    <tr><td style="text-align:center; font-weight:bold; vertical-align:middle;">F</td><td class="center" style="vertical-align:middle;">0-59</td><td class="center" style="vertical-align:middle;">0</td></tr>
