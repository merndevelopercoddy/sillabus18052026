{{> sidebar}}
<div id="content-wrapper" class="d-flex flex-column">
  <div id="content">
    {{> navbar}}
    <div class="container my-4">
      <div class="row">
        <div class="col-lg-10 shadow-lg px-5 py-3 mb-5 bg-body rounded offset-md-1">
          <!-- Agar ma'lumot mavjud bo'lsa jadval chiqadi -->
          {{#each data}}
          <table class="table table-bordered table-striped shadow-lg">
            <tbody>
              <tr>
                <th class="w-50">Yutuq nomi</th>
                <td>
                  {{yutuq_nomi}}
                </td>
              </tr>
              <tr>
                <th>Yili</th>
                <td>{{yutuq_yili}}</td>
              </tr>
                            <tr>
                <th>Daraja</th>
                <td>{{yutuq_daraja}}</td>
              </tr>
                            <tr>
                <th>O‘tkazilgan joyi</th>
                <td>{{yutuq_joyi}}</td>
              </tr>
              <tr>
                <th>
                  <a href="/student/yutuqlari/{{id}}" class="btn btn-success">✏️ Tahrirlash</a>
                </th>
                <td>

                  <a class="btn btn-danger" href="#" data-toggle="modal" data-target="#logoutModalYutuqlari{{this.id}}">
                    <i class="fas fa-trash fa fa-fw mr-2 text-gray-400"></i>
                    O‘chirish
                  </a>
                </td>
              </tr>
            </tbody>
          </table>
          <div class="modal fade" id="logoutModalYutuqlari{{this.id}}" tabindex="-1" role="dialog"
            aria-labelledby="exampleModalLabel" aria-hidden="true">
            <div class="modal-dialog" role="document">
              <div class="modal-content">
                <div class="modal-header">
                  <h5 class="modal-title" id="exampleModalLabel">Talaba yutug‘ini o'chirish</h5>
                  <button class="close" type="button" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                  </button>
                </div>
                <div class="modal-body">Rostdan ham o'chirasizmi?</div>
                <div class="modal-footer">
                  <button class="btn btn-secondary" type="button" data-dismiss="modal">Bekor qilish</button>
                  <form action="/student/yutuqlari/delete/{{this.id}}" method="POST" style="display:inline;"
                    class="delete-form">
                    <button type="submit" class="btn btn-danger">O‘chirish</button>
                  </form>
                </div>
              </div>
            </div>
          </div>
          {{/each}}


          <div class="container-fluid">

            <!-- Page Heading -->
            <div class="d-sm-flex align-items-center justify-content-center mb-4">
              <h1 class="h3 mb-0 text-gray-800">Yutuqlarni qo‘shish</h1>
            </div>
            <div class="row">
              <div class="col-lg-12  px-5 py-3  bg-body rounded">
                <form class="row g-3 needs-validation form-floating was-validated" method="POST"
                  action="/student/yutuqlari/add" novalidate>
                  <div class="col-md-12 p-3 mb-3 shadow  bg-body-tertiary rounded">
                    <!-- <p class="text-center fs-5">Ta'lim ma'lumotlari</p> -->
                    <div class="row">
                      <div class="col-md-8 form-floating mb-2">
                        <input type="text" class="form-control" id="floatingInput" placeholder="Yutuq nomi"
                          name="yutuq_nomi" required>
                        <label for="floatingInput" class="mx-2">Talaba erishgan yutuq nomi</label>
                      </div>
                      <div class="col-md-4 form-floating mb-2">
                        <select class="form-select" id="yearYutuq" name="yutuq_yili" required>
                          <option selected disabled></option>
                        </select>
                        <label for="yearYutuq" class="mx-2">Yili</label>
                      </div>
                                                                  <div class="col-md-8 form-floating mb-2">
                        <input type="text" class="form-control" id="floatingInputJoyi" placeholder="O'tkazilgan joyi"
                          name="yutuq_joyi" required>
                        <label for="floatingInputJoyi" class="mx-2">O‘tkazilgan joyi</label>
                      </div>
                                            <div class="col-md-4 mb-2 form-floating">
                        <select class="form-select" id="yutuq_daraja" name="yutuq_daraja" required>
                          <option value="" disabled selected>Tanlang...</option>
                          <option value="Mahalliy">Mahalliy</option>
                          <option value="Hududiy">Hududiy</option>
                          <option value="Xalqaro">Xalqaro</option>
                        </select>
                        <label for="yutuq_daraja" class="mx-2">Yutuq darajasi</label>
                      </div>

                    </div>
                  </div>
                  <div class="col-12">
                    <button type="submit" class="btn btn-primary">Qo‘shish</button>
                  </div>
                </form>
              </div>
            </div>


          </div>


        </div>
      </div>
      {{!-- <a href="/student/til_bilish/{{data.id}}" class="btn btn-success">✏️ Tahrirlash</a> --}}
    </div>
  </div>
  <footer class="sticky-footer bg-white">
    <div class="container my-auto">
      <div class="copyright text-center my-auto">
        <span>Barcha huquqlar himoyalangan &copy; 2025</span>
      </div>
    </div>
  </footer>
</div>
<script src="/js/student_talim.js"></script>