{{> sidebar}}
<div id="content-wrapper" class="d-flex flex-column">
  <div id="content">
    {{> navbar}}
    {{#if data}}
    <div class="container my-4">
      <div class="row">
        <div class="col-lg-10 shadow-lg px-5 py-3 mb-5 bg-body rounded offset-md-1">
          <!-- Agar ma'lumot mavjud bo'lsa jadval chiqadi -->
          <div class="d-sm-flex align-items-center justify-content-center mb-4">
            <h1 class="h3 mb-0 text-gray-800">Talabaning oilaviy holati bo‘yicha ma'lumoti</h1>
          </div>
          <table class="table table-bordered table-striped shadow-lg">
            <tbody>
              <tr>
                <th class="w-50">Jinsi</th>
                <td>
                  {{data.jinsi}}
                </td>
              </tr>
              <tr>
                <th>Oilaviy holati</th>
                <td>{{data.oilaviy_holat}}</td>
              </tr>
              <tr>
                <th>
                  <a href="/student/oilaviy_holati/edit" class="btn btn-success">✏️ Tahrirlash</a>
                </th>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
      {{!-- <a href="/student/til_bilish/{{data.id}}" class="btn btn-success">✏️ Tahrirlash</a> --}}
    </div>
    {{else}}
    <div class="container-fluid">
      <div class="row">
        <div class="col-lg-10 shadow-lg px-5 py-3 mb-5 bg-body rounded offset-md-1">
          <!-- Page Heading -->
          <div class="d-sm-flex align-items-center justify-content-center mb-4">
            <h1 class="h3 mb-0 text-gray-800 text-center">Oilaviy holati bo‘yicha ma'lumot qo‘shish</h1>
          </div>
          <div class="row">
            <div class="col-lg-12  px-lg-5 py-3  bg-body rounded">
              <form class="row g-3 needs-validation form-floating was-validated" method="POST"
                action="/student/oilaviy_holati/add" novalidate>
                <div class="col-md-12 p-3 mb-3 shadow  bg-body-tertiary rounded">
                  <!-- <p class="text-center fs-5">Ta'lim ma'lumotlari</p> -->
                  <div class="row">
                  <div class="col-md-6 mb-3  bg-body-tertiary">
                    <p class=" fs-5">Jinsi</p>
                    <div class="form-check">
                      <input class="form-check-input" type="radio" name="jinsi" id="erkak" value="Erkak" required>
                      <label class="form-check-label" for="erkak">
                        Erkak
                      </label>
                    </div>

                    <div class="form-check">
                      <input class="form-check-input" type="radio" name="jinsi" id="ayol" value="Ayol" required>
                      <label class="form-check-label" for="ayol">
                        Ayol
                      </label>
                    </div>
                  </div>
                    <div class="col-md-6 mb-3 form-floating">
                      <select class="form-select" id="yutuq_daraja" name="oilaviy_holat" required>
                        <option value="" disabled selected>Tanlang...</option>
                        <option value="Turmush qurgan">Turmush qurgan</option>
                        <option value="Turmush qurmagan">Turmush qurmagan</option>
                        <option value="Ajrashgan">Ajrashgan</option>
                        <option value="Beva">Beva</option>
                      </select>
                      <label for="yutuq_daraja" class="mx-2">Oilaviy holati</label>
                    </div>
                    </div>
                </div>
                <div class="col-12">
                  <button type="submit" class="btn btn-primary">Qo‘shish</button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
    {{/if}}
  </div>
  <footer class="sticky-footer bg-white">
    <div class="container my-auto">
      <div class="copyright text-center my-auto">
        <span>Barcha huquqlar himoyalangan &copy; 2025</span>
      </div>
    </div>
  </footer>
</div>
<script src="/js/student_talim.js"></script>