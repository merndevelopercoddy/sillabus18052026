{{> sidebar}}
<div id="content-wrapper" class="d-flex flex-column">
  <div id="content">
    {{> navbar}}
    {{#if data}}
    <div class="container my-4">
      <div class="row">
        <div class="col-lg-10 shadow-lg px-5 py-3 mb-5 bg-body rounded offset-md-1">
          <!-- Agar ma'lumot mavjud bo'lsa jadval chiqadi -->
          <div class="d-sm-flex align-items-center justify-content-center mb-4">
            <h1 class="h3 mb-0 text-gray-800">Talabalar o‘rtasida huquqbuzarlik va jinoyatchilik holatlari</h1>
          </div>
          <table class="table table-bordered table-striped shadow-lg">
            <tbody>
              {{#if data.notinch}}
              <tr>
                <td>Notinch oiladagi yoshlar</td>
              </tr>
              {{else}}{{/if}}
              {{#if data.ytabiatli}}
              <tr>
                <td>Yengil tabiatli xotin-qiz</td>
              </tr>
              {{else}}{{/if}}
              {{#if data.jiem}}
              <tr>
                <td>JIEMdan qaytganlar</td>
              </tr>
              {{else}}{{/if}}
              {{#if data.probatsiya}}
              <tr>
                <td>Probatsiya hisobida turuvchilar</td>
              </tr>
              {{else}}{{/if}}
              {{#if data.horderi}}
              <tr>
                <td>Tazyiq va zo'ravonlikdan jabrlanganligi sababli "himoya orderi" berilgan xotin-qizlar</td>
              </tr>
              {{else}}{{/if}}
              {{#if data.jqasd}}
              <tr>
                <td>O'z joniga qasd qilishga moyilligi bo'lganlar</td>
              </tr>
              {{else}}{{/if}}
              {{#if data.mhuquqbuzarlik}}
              <tr>
                <td>Ma'muriy huquqbuzarlik sodir etganlar</td>
              </tr>
              {{else}}{{/if}}
              <tr>
                <th>
                  <a href="/student/huquqbuzarlik/edit" class="btn btn-success">✏️ Tahrirlash</a>
                </th>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
      {{!-- <a href="/student/til_bilish/{{data.id}}" class="btn btn-success">✏️ Tahrirlash</a> --}}
    </div>
    {{else}}
    <div class="container-fluid">
      <div class="row">
        <div class="col-lg-10 shadow-lg px-5 py-3 mb-5 bg-body rounded offset-md-1">
          <!-- Page Heading -->
          <div class="d-sm-flex align-items-center justify-content-center mb-4">
            <h1 class="h3 mb-0 text-gray-800 text-center">Talabalar o‘rtasida huquqbuzarlik va jinoyatchilik holatlari</h1>
          </div>
          <div class="row">
            <div class="col-lg-12  px-lg-5 py-3  bg-body rounded">
              <form class="row g-3 needs-validation form-floating" method="POST" action="/student/huquqbuzarlik/add">
                <div class="col-md-12 p-3 mb-3 shadow  bg-body-tertiary rounded">
                  <!-- <p class="text-center fs-5">Ta'lim ma'lumotlari</p> -->
                  <div class="row">
                    <div class="col-md-6 mb-3  bg-body-tertiary">
                      <div class="form-check">
                        <input name="notinch" class="form-check-input" type="checkbox" value="Ha" id="defaultCheck1">
                        <label class="form-check-label" for="defaultCheck1">
                          Notinch oiladagi yoshlar
                        </label>
                      </div>
                    </div>
                    <div class="col-md-6 mb-3  bg-body-tertiary">
                      <div class="form-check">
                        <input name="ytabiatli" class="form-check-input" type="checkbox" value="Ha" id="defaultCheck2">
                        <label class="form-check-label" for="defaultCheck2">
                          Yengil tabiatli xotin-qiz
                        </label>
                      </div>
                    </div>
                    <div class="col-md-6 mb-3  bg-body-tertiary">
                      <div class="form-check">
                        <input name="jiem" class="form-check-input" type="checkbox" value="Ha"
                          id="defaultCheck3">
                        <label class="form-check-label" for="defaultCheck3">
                          JIEMdan qaytganlar
                        </label>
                      </div>
                    </div>
                    <div class="col-md-6 mb-3  bg-body-tertiary">
                      <div class="form-check">
                        <input name="probatsiya" class="form-check-input" type="checkbox" value="Ha"
                          id="defaultCheck4">
                        <label class="form-check-label" for="defaultCheck4">
                          Probatsiya hisobida turuvchilar
                        </label>
                      </div>
                    </div>
                    <div class="col-md-6 mb-3  bg-body-tertiary">
                      <div class="form-check">
                        <input name="horderi" class="form-check-input" type="checkbox" value="Ha"
                          id="defaultCheck5">
                        <label class="form-check-label" for="defaultCheck5">
                         Tazyiq va zo'ravonlikdan jabrlanganligi sababli "himoya orderi" berilgan xotin-qizlar
                        </label>
                      </div>
                    </div>
                    <div class="col-md-6 mb-3  bg-body-tertiary">
                      <div class="form-check">
                        <input name="jqasd" class="form-check-input" type="checkbox" value="Ha" id="defaultCheck6">
                        <label class="form-check-label" for="defaultCheck6">
                         O'z joniga qasd qilishga moyilligi bo'lganlar
                        </label>
                      </div>
                    </div>
                    <div class="col-md-6 mb-3  bg-body-tertiary">
                      <div class="form-check">
                        <input name="mhuquqbuzarlik" class="form-check-input" type="checkbox" value="Ha" id="defaultCheck7">
                        <label class="form-check-label" for="defaultCheck7">
                          Ma'muriy huquqbuzarlik sodir etganlar 
                        </label>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="col-12">
                  <button type="submit" class="btn btn-primary">Qo‘shish</button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
    {{/if}}
  </div>
  <footer class="sticky-footer bg-white">
    <div class="container my-auto">
      <div class="copyright text-center my-auto">
        <span>Barcha huquqlar himoyalangan &copy; 2025</span>
      </div>
    </div>
  </footer>
</div>
<script src="/js/student_talim.js"></script>