{{> sidebar}}
<div id="content-wrapper" class="d-flex flex-column">
  <div id="content">
    {{> navbar}}
    <div class="container-fluid">
      <div class="row">
        <div class="col-lg-10 shadow-lg px-5 py-3 mb-5 bg-body rounded offset-md-1">
          <!-- Page Heading -->
          <div class="d-sm-flex align-items-center justify-content-center mb-4">
            <h1 class="h3 mb-0 text-gray-800 text-center">Oilaviy holati ma'lumotlarini tahrirlash</h1>
          </div>
          <div class="row">
            <div class="col-lg-12  px-lg-5 py-3  bg-body rounded">
              <form class="row g-3 needs-validation form-floating was-validated" method="POST"
                action="/student/oilaviy_holati/edit" novalidate>
                
                <div class="col-md-12 p-3 mb-3 shadow  bg-body-tertiary rounded">
                  <div class="row">

                    <!-- Jinsi -->
                    <div class="col-md-6 mb-3 bg-body-tertiary">
                      <p class="fs-5">Jinsi</p>
                      
                      <div class="form-check">
                        <input class="form-check-input" type="radio" name="jinsi" id="erkak" value="Erkak" 
                          {{#if (eq data.jinsi "Erkak")}}checked{{/if}} required>
                        <label class="form-check-label" for="erkak">Erkak</label>
                      </div>

                      <div class="form-check">
                        <input class="form-check-input" type="radio" name="jinsi" id="ayol" value="Ayol" 
                          {{#if (eq data.jinsi "Ayol")}}checked{{/if}} required>
                        <label class="form-check-label" for="ayol">Ayol</label>
                      </div>
                    </div>

                    <!-- Oilaviy holati -->
                    <div class="col-md-6 mb-3 form-floating">
                      <select class="form-select" id="oilaviy_holat" name="oilaviy_holat" required>
                        <option value="" disabled>Tanlang...</option>
                        <option value="Turmush qurgan" {{#if (eq data.oilaviy_holat "Turmush qurgan")}}selected{{/if}}>Turmush qurgan</option>
                        <option value="Turmush qurmagan" {{#if (eq data.oilaviy_holat "Turmush qurmagan")}}selected{{/if}}>Turmush qurmagan</option>
                        <option value="Ajrashgan" {{#if (eq data.oilaviy_holat "Ajrashgan")}}selected{{/if}}>Ajrashgan</option>
                        <option value="Beva" {{#if (eq data.oilaviy_holat "Beva")}}selected{{/if}}>Beva</option>
                      </select>
                      <label for="oilaviy_holat" class="mx-2">Oilaviy holati</label>
                    </div>

                  </div>
                </div>

                <div class="col-12">
                  <button type="submit" class="btn btn-primary">Tahrirlash</button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <footer class="sticky-footer bg-white">
    <div class="container my-auto">
      <div class="copyright text-center my-auto">
        <span>Barcha huquqlar himoyalangan &copy; 2025</span>
      </div>
    </div>
  </footer>
</div>
<script src="/js/student_talim.js"></script>
