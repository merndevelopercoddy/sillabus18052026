{{> sidebar}}

<div id="content-wrapper" class="d-flex flex-column">
  <div id="content">
    {{> navbar}}

    <div class="container my-5">
      <div class="text-center mb-4">
        <h2 class="fw-bold">📄 CV Dizaynini Tanlang</h2>
        <p class="text-muted">Quyidagi dizaynlardan birini tanlang va PDF shaklida yuklab oling</p>
      </div>

      <div class="row justify-content-center">

        {{!-- Dizayn kartalari --}}
        {{#each designs}}
        <div class="col-md-4 mb-4">
          <div class="card shadow-sm border-0 cv-card">
            <a href="/student/cv/{{this}}" >
            <img src="/img/cv-design{{this}}-preview.jpg" class="card-img-top" alt="CV Dizayn {{this}}">
            </a>
            <div class="card-body text-center">
              {{!-- <h5 class="card-title fw-semibold mb-3">Dizayn {{this}}</h5> --}}
              <div class="d-grid gap-2">
                <a href="/student/cv/{{this}}" class="btn btn-outline-primary">
                  🔍 Ko‘rish
                </a>
                {{!-- <a href="/student/cv/download/{{this}}" class="btn btn-success btn-sm">
                  ⬇ Yuklab olish (PDF)
                </a> --}}
              </div>
            </div>
          </div>
        </div>
        {{/each}}

      </div>

      <div class="text-center mt-4">
        <a href="/student/dashboard" class="btn btn-outline-secondary">⬅ Orqaga qaytish</a>
      </div>
    </div>
  </div>

  <footer class="sticky-footer bg-white">
    <div class="container my-auto">
      <div class="copyright text-center my-auto">
        <span>Barcha huquqlar himoyalangan &copy; 2025</span>
      </div>
    </div>
  </footer>
</div>

<style>
  .cv-card {
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    border-radius: 10px;
    overflow: hidden;
  }

  .cv-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.15);
  }

  .cv-card img {
    object-fit: cover;
    border-bottom: 1px solid #eaeaea;

      {
        {
        !-- height: 340px;
        --
      }
    }
  }

  .card-body .btn {
    border-radius: 6px;
    font-size: 14px;
  }

  h2 {
    color: #003366;
  }
</style>