        <tbody>
  {{#each students}}
  <tr>
    <td>{{addOne ../startIndex @index}}</td>
    <td>{{this.familiya}}</td>
    <td>{{this.ism}}</td>
    <td>{{this.sharif}}</td>
    <td>{{this.guruh}}</td>
    <td>{{this.login}}</td>
    <td>{{#if this.is_active}}✅ Aktiv{{else}}❌ Bloklangan{{/if}}</td>
    <td>
      <a href="/admin/student/{{id}}" class="btn btn-sm btn-info">Ko‘rish</a>

      <form method="POST" action="/admin/student/toggle/{{id}}" style="display:inline;">
        <button type="submit" class="btn btn-sm btn-warning">Faol/Nofaol</button>
      </form>

      <button
        type="button"
        class="btn btn-danger btn-sm my-2 px-3"
        data-bs-toggle="modal"
        data-bs-target="#logoutModalDel{{id}}">
        O‘chirish
      </button>
    </td>
  </tr>

  <div class="modal fade" id="logoutModalDel{{id}}" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Talabani o‘chirish</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          Rostdan ham o‘chirasizmi?
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
            Bekor qilish
          </button>

          <form action="/admin/student/delete/{{id}}" method="POST" style="display:inline;">
            <button type="submit" class="btn btn-danger">O‘chirish</button>
          </form>
        </div>
      </div>
    </div>
  </div>
  {{/each}}
</tbody>
      </table>


      <!-- Sahifalash -->
      <nav aria-label="Sahifalar">
        <ul class="pagination justify-content-center">

          {{!-- Oldingi --}}
          {{#if (gt currentPage 1)}}
          <li class="page-item">
            <a class="page-link"
              href="?page={{decrement currentPage}}&limit={{limit}}&sort={{sort}}&order={{order}}&search={{search}}">
              « Oldingi
            </a>
          </li>
          {{/if}}

          {{!-- Qisqartirilgan sahifalar: 1 ... 5 6 [7] 8 9 ... 26 --}}
          {{#each (generatePagination currentPage totalPages 2)}}
          {{#if (eq this "...")}}
          <li class="page-item disabled"><span class="page-link">...</span></li>
          {{else}}
          <li class="page-item {{#if (eq ../currentPage this)}}active{{/if}}">
            <a class="page-link"
              href="?page={{this}}&limit={{../limit}}&sort={{../sort}}&order={{../order}}&search={{../search}}">
              {{this}}
            </a>
          </li>
          {{/if}}
          {{/each}}

          {{!-- Keyingi --}}
          {{#if (lt currentPage totalPages)}}
          <li class="page-item">
            <a class="page-link"
              href="?page={{increment currentPage}}&limit={{limit}}&sort={{sort}}&order={{order}}&search={{search}}">
              Keyingi »
            </a>
          </li>
          {{/if}}

        </ul>
      </nav>



    </div>



  </div>
  <footer class="sticky-footer bg-white">
    <div class="container my-auto">
      <div class="copyright text-center my-auto">
        <span>Barcha huquqlar himoyalangan &copy; 2025</span>
      </div>
    </div>
  </footer>
</div>

<script src="/js/pagination.js"></script>
