    <div class="container mt-4">
      <h4>Talabalar ro‘yxati (Jami: {{totalStudents}} ta)</h4>
      <form id="searchForm" method="get" class="d-flex mb-3" role="search">
        <input class="form-control me-2" type="search" name="search" placeholder="Familiya yoki ismni kiriting..."
          value="{{search}}">
        <input type="hidden" name="limit" value="{{limit}}">
        <input type="hidden" name="sort" value="{{sort}}">
        <input type="hidden" name="order" value="{{order}}">
        <button class="btn btn-primary" type="submit">Qidirish</button>
      </form>
      <!-- Har sahifada nechta ko‘rsatish -->
      <form id="limitForm" class="mb-3">
        <label>Har sahifada ko‘rsatish:</label>
        <select id="limitSelect" class="form-select form-select-sm" style="width: 120px; display:inline;">
          <option value="25" {{#if (eq limit 25)}}selected{{/if}}>25</option>
          <option value="50" {{#if (eq limit 50)}}selected{{/if}}>50</option>
          <option value="100" {{#if (eq limit 100)}}selected{{/if}}>100</option>
        </select>
      </form>



      <!-- Jadval -->
      <table class="table table-striped table-bordered mt-2">
        <thead>
          <tr>
            <th>#</th>

            <th>
              <a
                href="?page=1&limit={{limit}}&sort=familiya&order={{#if (and (eq sort 'familiya') (eq order 'ASC'))}}desc{{else}}asc{{/if}}">
                Familiya
                {{#if (eq sort 'familiya')}}
                {{#if (eq order 'ASC')}}▲{{else}}▼{{/if}}
                {{/if}}
              </a>
            </th>

            <th>
              <a
                href="?page=1&limit={{limit}}&sort=ism&order={{#if (and (eq sort 'ism') (eq order 'ASC'))}}desc{{else}}asc{{/if}}">
                Ism
                {{#if (eq sort 'ism')}}
                {{#if (eq order 'ASC')}}▲{{else}}▼{{/if}}
                {{/if}}
              </a>
            </th>

            <th>
              <a
                href="?page=1&limit={{limit}}&sort=sharif&order={{#if (and (eq sort 'sharif') (eq order 'ASC'))}}desc{{else}}asc{{/if}}">
                Sharif
                {{#if (eq sort 'sharif')}}
                {{#if (eq order 'ASC')}}▲{{else}}▼{{/if}}
                {{/if}}
              </a>
            </th>

            <th>
              <a
                href="?page=1&limit={{limit}}&sort=guruh&order={{#if (and (eq sort 'guruh') (eq order 'ASC'))}}desc{{else}}asc{{/if}}">
                Guruh
                {{#if (eq sort 'guruh')}}
                {{#if (eq order 'ASC')}}▲{{else}}▼{{/if}}
                {{/if}}
              </a>
            </th>

            <th>
              <a
                href="?page=1&limit={{limit}}&sort=login&order={{#if (and (eq sort 'login') (eq order 'ASC'))}}desc{{else}}asc{{/if}}">
                Login
                {{#if (eq sort 'login')}}
                {{#if (eq order 'ASC')}}▲{{else}}▼{{/if}}
                {{/if}}
              </a>
            </th>
            <th>Holati</th>
            <th>Amallar</th>
          </tr>
        </thead>

