{{> oqituvchi_sidebar}}
<div id="content-wrapper" class="d-flex flex-column">
  <div id="content">
    {{> navbar}}
    <div class="container-fluid">
      <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">O'qituvchi Dashboard</h1>
        <div>
          {{#if kafedra}}<span class="badge badge-info p-2 mr-1">{{kafedra.nomi}}</span>{{/if}}
          {{#if faolYil}}<span class="badge badge-success p-2">Faol yil: {{faolYil.nomi}}</span>{{/if}}
        </div>
      </div>
      {{#unless kafedra}}
      <div class="alert alert-warning"><i class="fas fa-exclamation-triangle mr-2"></i>Sizga hali kafedra biriktirilmagan. Kafedra mudiri bilan bog'laning.</div>
      {{/unless}}
      <div class="row">
        <div class="col-xl-4 col-md-6 mb-4">
          <a href="/oqituvchi/fanlar" class="text-decoration-none">
            <div class="card border-left-info shadow h-100 py-2">
              <div class="card-body">
                <div class="row no-gutters align-items-center">
                  <div class="col mr-2">
                    <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Mening fanlarim</div>
                    <div class="h5 mb-0 font-weight-bold text-gray-800">{{fanlarCount}}</div>
                    {{#if faolYil}}<small class="text-muted">{{faolYil.nomi}} yili</small>{{/if}}
                  </div>
                  <div class="col-auto"><i class="fas fa-book fa-2x text-gray-300"></i></div>
                </div>
              </div>
            </div>
          </a>
        </div>
      </div>
      <div class="row">
        <div class="col-lg-12">
          <div class="card shadow">
            <div class="card-header"><h6 class="m-0 font-weight-bold text-info">Tezkor havolalar</h6></div>
            <div class="card-body">
              <a href="/oqituvchi/fanlar" class="btn btn-info mr-2 mb-2">
                <i class="fas fa-book mr-1"></i> Mening fanlarim
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <footer class="sticky-footer bg-white">
    <div class="container my-auto"><div class="copyright text-center my-auto"><span>Barcha huquqlar himoyalangan &copy; 2026</span></div></div>
  </footer>
</div>
