{{> oqituvchi_sidebar}}
<div id="content-wrapper" class="d-flex flex-column">
  <div id="content">
    {{> navbar}}
    <div class="container-fluid">

      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">Mening fanlarim</h1>
        {{#if faolYil}}
        <span class="badge badge-success p-2">Faol yil: {{faolYil.nomi}}</span>
        {{/if}}
      </div>

      {{!-- Yil filtri --}}
      <div class="card shadow mb-4">
        <div class="card-body py-2">
          <form method="GET" action="/oqituvchi/fanlar" class="form-inline">
            <label class="mr-2 font-weight-bold">Akademik yil:</label>
            <select name="yil" class="form-control form-control-sm mr-2" onchange="this.form.submit()">
              <option value="">— Barcha yillar —</option>
              {{#each akademikYillar}}
              <option value="{{this.id}}" {{#if (eq this.id ../selectedYilId)}}selected{{/if}}>
                {{this.nomi}}{{#if this.faol}} (faol){{/if}}
              </option>
              {{/each}}
            </select>
          </form>
        </div>
      </div>

      {{#if fanlar.length}}
      <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
          <h6 class="m-0 font-weight-bold text-info">Biriktirilgan fanlar</h6>
          <span class="badge badge-secondary">{{fanlar.length}} ta</span>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-bordered table-hover mb-0 align-middle">
              <thead class="thead-light">
                <tr>
                  <th>#</th>
                  <th>Fan nomi</th>
                  <th>Fan kodi</th>
                  <th>Kafedra</th>
                  <th>Grade / ECTS</th>
                  <th>Semestr</th>
                  <th>Soatlar</th>
                  <th class="text-center">Yil</th>
                  <th class="text-center">Mas'ul</th>
                  <th class="text-center">Sillabus</th>
                </tr>
              </thead>
              <tbody>
                {{#each fanlar}}
                <tr>
                  <td>{{increment @index}}</td>
                  <td>
                    <strong>{{this.f_nomi}}</strong><br>
                    <small class="text-muted">{{this.t_shakli}}</small>
                  </td>
                  <td><span class="badge badge-primary">{{this.fan_kodi}}</span></td>
                  <td>
                    {{#if this.kafedra_nomi}}
                    <small class="text-muted">{{this.kafedra_nomi}}</small>
                    {{else}}
                    <span class="text-muted">—</span>
                    {{/if}}
                  </td>
                  <td>
                    <small>Grade: <b>{{this.grade}}</b></small><br>
                    <small>ECTS: <b>{{this.ects}}</b></small>
                  </td>
                  <td>
                    {{#each this.semestr}}
                    <span class="badge badge-info mb-1">{{this}}-sem</span>
                    {{/each}}
                  </td>
                  <td>
                    <small>Aud: <b>{{this.auditoriya_soat}}</b></small><br>
                    <small>Mustaqil: <b>{{this.mustaqil_soat}}</b></small>
                  </td>
                  <td class="text-center">
                    {{#if this.yil_nomi}}
                    <span class="badge badge-secondary">{{this.yil_nomi}}</span>
                    {{else}}
                    <span class="text-muted">—</span>
                    {{/if}}
                  </td>
                  <td class="text-center">
                    {{#if this.mas_ul}}
                    <span class="badge badge-warning"><i class="fas fa-star mr-1"></i>Ha</span>
                    {{else}}
                    <span class="text-muted">—</span>
                    {{/if}}
                  </td>
                  <td class="text-center">
                    {{#if this.sillabus_id}}
                    <a href="/oqituvchi/sillabuslar/{{this.sillabus_id}}" class="btn btn-sm btn-info">
                      <i class="fas fa-file-alt mr-1"></i>Ochish
                    </a>
                    {{else}}
                    <form method="POST" action="/oqituvchi/sillabuslar/create" class="d-inline">
                      <input type="hidden" name="fan_oqituvchi_id" value="{{this.fo_id}}">
                      <button type="submit" class="btn btn-sm btn-outline-info">
                        <i class="fas fa-plus mr-1"></i>Yaratish
                      </button>
                    </form>
                    {{/if}}
                  </td>
                </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        </div>
      </div>
      {{else}}
      <div class="alert alert-info">
        <i class="fas fa-info-circle mr-2"></i>
        {{#if selectedYilId}}
        Tanlangan akademik yil uchun biriktirilgan fanlar yo'q.
        {{else}}
        Sizga hali hech qanday fan biriktirilmagan. Kafedra mudiri bilan bog'laning.
        {{/if}}
      </div>
      {{/if}}

    </div>
  </div>
  <footer class="sticky-footer bg-white">
    <div class="container my-auto">
      <div class="copyright text-center my-auto">
        <span>Barcha huquqlar himoyalangan &copy; 2026</span>
      </div>
    </div>
  </footer>
</div>
