<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Parolni yangilash</title>
  <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet">
  <link href="/css/sb-admin-2.min.css" rel="stylesheet">
</head>
<body class="bg-gradient-primary">
  <div class="container">
    <div class="row justify-content-center" style="min-height:100vh; align-items:center;">
      <div class="col-xl-5 col-lg-6 col-md-8">
        <div class="card o-hidden border-0 shadow-lg my-5">
          <div class="card-body p-0">
            <div class="p-5">
              <div class="text-center mb-4">
                <i class="fas fa-lock fa-3x text-primary mb-3"></i>
                <h4 class="text-gray-900">Parolni yangilash</h4>
                <p class="text-muted small">Xavfsizlik uchun yangi parol o'rnating</p>
              </div>

              {{#if error}}
              <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle mr-1"></i> {{error}}
              </div>
              {{/if}}

              <form method="POST" action="/change-password">
                <div class="form-group">
                  <label class="small font-weight-bold text-gray-600">Yangi parol <span class="text-danger">*</span></label>
                  <input type="password" name="new_password" class="form-control form-control-user"
                         placeholder="Kamida 6 belgi" required minlength="6" autofocus>
                </div>
                <div class="form-group">
                  <label class="small font-weight-bold text-gray-600">Yangi parolni takrorlang <span class="text-danger">*</span></label>
                  <input type="password" name="new_password2" class="form-control form-control-user"
                         placeholder="Parolni qayta kiriting" required minlength="6">
                </div>
                <button type="submit" class="btn btn-primary btn-user btn-block">
                  <i class="fas fa-save mr-1"></i> Saqlash
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
