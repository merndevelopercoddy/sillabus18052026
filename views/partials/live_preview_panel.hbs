<button type="button" id="livePreviewToggle" class="btn btn-info no-print"
  style="position:fixed; bottom:24px; right:24px; z-index:1040; border-radius:24px; box-shadow:0 2px 10px rgba(0,0,0,.25); padding:10px 18px;">
  <i class="fas fa-eye mr-1"></i>Jonli koʻrinish
</button>

<div id="livePreviewPanel" class="d-none no-print"
  style="position:fixed; top:0; right:0; bottom:0; width:520px; max-width:92vw; background:#f4f6f9; box-shadow:-4px 0 16px rgba(0,0,0,.15); z-index:1050; overflow-y:auto;">
  <div class="d-flex justify-content-between align-items-center px-3 py-2 bg-white border-bottom"
    style="position:sticky; top:0; z-index:1;">
    <strong class="text-gray-800"><i class="fas fa-eye mr-1"></i>Jonli koʻrinish</strong>
    <button type="button" id="livePreviewClose" class="btn btn-sm btn-outline-secondary">
      <i class="fas fa-times"></i>
    </button>
  </div>
  <div id="livePreviewContent" class="p-3">
    <p class="text-center text-muted small mt-4">Maydonlarni toʻldiring — koʻrinish shu yerda yangilanadi.</p>
  </div>
</div>

