{{!-- 1. Sarlavha --}}
<table style="width:100%; margin-bottom:16px;">
  <tr>
    <td style="width:60%; vertical-align:top; text-align:center; padding:8px;">
      {{#if tashkilot.logo}}
      <img src="/uploads/{{tashkilot.logo}}" alt="Logo" style="max-width:180px; max-height:100px;">
      {{/if}}
    </td>
    <td style="width:40%; vertical-align:top; padding:8px; text-align:center; color:#1a4f91; font-size:13px; line-height:1;">
      <div style="font-weight:bold; margin:0;">{{#if tashkilot.tashkilot_nomi}}{{tashkilot.tashkilot_nomi}}{{else}}Universitet{{/if}}</div>
      <div style="font-weight:bold; margin:0;">Akademik ishlar boʻyicha</div>
      <div style="font-weight:bold; margin:0;">prorektor {{#if tashkilot.masul}}{{tashkilot.masul}}{{else}}_________________{{/if}}</div>
      <div style="margin-top:24px; border-bottom:1px solid #1a4f91; width:80%; display:inline-block;">&nbsp;</div>
      <div style="margin-top:8px; font-weight:bold;">{{#if sillabus.yil_nomi}}{{firstYear sillabus.yil_nomi}}{{else}}20___{{/if}} yil &ldquo;______&rdquo; ___________</div>
    </td>
  </tr>
</table>

{{!-- 2. Fan nomi va sillabus sarlavhasi --}}
<h3 style="text-align:center; font-weight:bold; text-transform:uppercase; margin:16px 0 4px; font-size:13px;">
  {{sillabus.f_nomi}}
</h3>
<h4 style="text-align:center; font-weight:bold; margin:0 0 16px; font-size:13px;">
  FANNING OʻQUV DASTURI (SILLABUS)
</h4>

{{!-- 3. Asosiy maʻlumotlar jadvali --}}
<table style="width:100%; margin-bottom:16px; font-size:13px;">
  <tr>
    <td style="border:1px solid #333; padding:6px; font-weight:bold; width:25%; text-align:left; vertical-align:middle;">Akademik daraja</td>
    <td style="border:1px solid #333; padding:6px; width:22%; text-align:center; vertical-align:middle;">{{#if sillabus.grade}}{{capitalize sillabus.grade}}{{else}}Bakalavr{{/if}}</td>
    <td style="border:1px solid #333; padding:6px; font-weight:bold; width:22%; text-align:center; vertical-align:middle;">Taʻlim yoʻnalishi</td>
    <td style="border:1px solid #333; padding:6px; width:31%; text-align:center; vertical-align:middle;">
      {{#if sillabus.t_yunalish.length}}
      {{#each sillabus.t_yunalish}}<div>{{this}}</div>{{/each}}
      {{else}}—{{/if}}
    </td>
  </tr>
  <tr>
    <td style="border:1px solid #333; padding:6px; font-weight:bold; text-align:left; vertical-align:middle;">Fan kodi</td>
    <td style="border:1px solid #333; padding:6px; text-align:center; vertical-align:middle;">{{sillabus.fan_kodi}}</td>
    <td style="border:1px solid #333; padding:6px; font-weight:bold; text-align:center; vertical-align:middle;">Taʻlim shakli</td>
    <td style="border:1px solid #333; padding:6px; text-align:center; vertical-align:middle;">{{#if sillabus.t_shakli}}{{capitalize sillabus.t_shakli}}{{else}}Kunduzgi{{/if}}</td>
  </tr>
  <tr>
    <td style="border:1px solid #333; padding:6px; font-weight:bold; text-align:left; vertical-align:middle;">Semestr</td>
    <td style="border:1px solid #333; padding:6px; text-align:center; vertical-align:middle;">{{#if sillabus.semestr}}{{sillabus.semestr}}-semestr{{else}}—{{/if}}</td>
    <td style="border:1px solid #333; padding:6px; font-weight:bold; text-align:center; vertical-align:middle;">Modulning davomiyligi</td>
    <td style="border:1px solid #333; padding:6px; text-align:center; vertical-align:middle;">{{#if sillabus.davomiyligi}}{{sillabus.davomiyligi}} hafta{{else}}—{{/if}}</td>
  </tr>
  <tr>
    <td style="border:1px solid #333; padding:6px; font-weight:bold; text-align:left; vertical-align:middle;">Kredit hajmi</td>
    <td style="border:1px solid #333; padding:6px; text-align:center; vertical-align:middle;">{{#if sillabus.ects}}ECTS: {{sillabus.ects}}{{else}}—{{/if}}</td>
    <td style="border:1px solid #333; padding:6px; font-weight:bold; text-align:center; vertical-align:middle;">Tayyorladi</td>
    <td style="border:1px solid #333; padding:6px; text-align:center; vertical-align:middle;">{{#if tashkilot.short_name}}{{tashkilot.short_name}}{{else}}—{{/if}}</td>
  </tr>
  <tr>
    <td style="border:1px solid #333; padding:6px; font-weight:bold; text-align:left; vertical-align:middle;">Ajratilgan akademik soat hajmi</td>
    <td style="border:1px solid #333; padding:0; text-align:center; vertical-align:middle;">
      <table style="width:100%;">
        <tr><td style="padding:4px; border-bottom:1px solid #333; text-align:center;">{{sum sillabus.auditoriya_soat sillabus.mustaqil_soat}}</td></tr>
        <tr>
          <td style="padding:0;">
            <table style="width:100%;">
              <tr>
                <td style="width:50%; padding:4px; border-right:1px solid #333; text-align:center;">{{#if sillabus.auditoriya_soat}}{{sillabus.auditoriya_soat}}{{else}}0{{/if}}<br><span style="font-size:11px;">(aud)</span></td>
                <td style="width:50%; padding:4px; text-align:center;">{{#if sillabus.mustaqil_soat}}{{sillabus.mustaqil_soat}}{{else}}0{{/if}}<br><span style="font-size:11px;">(must)</span></td>
              </tr>
            </table>
          </td>
        </tr>
      </table>
    </td>
    <td style="border:1px solid #333; padding:6px; font-weight:bold; text-align:center; vertical-align:middle;">Talabalarni erkin qabul qilish kuni</td>
    <td style="border:1px solid #333; padding:6px; text-align:center; vertical-align:middle;">{{#if showInlineEdit}}<span{{{editableAttrs "talabalarni_qabul_kuni" showInlineEdit}}} data-placeholder="masalan: Payshanba, 14:00">{{sillabus.talabalarni_qabul_kuni}}</span>{{else}}{{#if sillabus.talabalarni_qabul_kuni}}{{sillabus.talabalarni_qabul_kuni}}{{else}}—{{/if}}{{/if}}</td>
  </tr>
</table>

{{!-- blank 13px line, matching the "1 enter" gap requested between the info table and this block --}}
<p style="margin:0; font-size:13px; line-height:1.15;">&nbsp;</p>

{{!-- 4. Tuzuvchi --}}
<table style="width:100%; margin-bottom:8px; border-collapse:collapse; font-size:13px;">
  <tr>
    <td style="width:20%; vertical-align:top; padding:0;"><strong>Tuzuvchi:</strong></td>
    <td style="vertical-align:top; padding:0; line-height:1.15;">
      {{#if showInlineEdit}}
      <div><strong><span{{{editableAttrs "tuzuvchi_fish" showInlineEdit}}} data-placeholder="F.I.Sh. kiriting">{{sillabus.tuzuvchi_fish}}</span></strong></div>
      <div><span{{{editableAttrs "tuzuvchi_lavozim" showInlineEdit}}} data-placeholder="Lavozimi kiriting">{{sillabus.tuzuvchi_lavozim}}</span></div>
      <div>Tel: <span{{{editableAttrs "tuzuvchi_tel" showInlineEdit}}} data-placeholder="+998...">{{sillabus.tuzuvchi_tel}}</span></div>
      {{else}}
      <div><strong>{{#if sillabus.tuzuvchi_fish}}{{sillabus.tuzuvchi_fish}}{{else}}{{#if sillabus.oqituvchi_nomi}}{{sillabus.oqituvchi_nomi}}{{else}}{{sillabus.oqituvchi_login}}{{/if}}{{/if}}</strong></div>
      {{#if sillabus.tuzuvchi_lavozim}}<div>{{sillabus.tuzuvchi_lavozim}}</div>{{/if}}
      {{#if sillabus.tuzuvchi_tel}}<div>Tel: {{sillabus.tuzuvchi_tel}}</div>{{/if}}
      {{/if}}
    </td>
  </tr>
</table>

{{!-- 5. Taqrizchilar --}}
{{#if showInlineEdit}}
<table style="width:100%; margin-bottom:8px; border-collapse:collapse; font-size:13px;">
  <tr>
    <td style="width:20%; vertical-align:top; padding:0;"><strong>Taqrizchilar:</strong></td>
    <td style="vertical-align:top; padding:0; line-height:1.15;">
      <div data-inline-edit-panel data-refresh-url="{{urlPrefix}}/sillabuslar/{{sillabus.id}}/taqrizchi/fragment">{{> taqrizchi_editable_list rows=taqrizchilar}}</div>
    </td>
  </tr>
</table>
{{else}}
{{#if taqrizchilar.length}}
<table style="width:100%; margin-bottom:8px; border-collapse:collapse; font-size:13px;">
  <tr>
    <td style="width:20%; vertical-align:top; padding:0;"><strong>Taqrizchilar:</strong></td>
    <td style="vertical-align:top; padding:0; line-height:1.15;">
      {{#each taqrizchilar}}
      <div><strong>{{this.tartib}}. {{this.fish}}</strong></div>
      {{#if this.lavozim}}<div>{{this.lavozim}}</div>{{/if}}
      {{/each}}
    </td>
  </tr>
</table>
{{/if}}
{{/if}}

{{!-- 6. Kengash majlisi --}}
{{#if showInlineEdit}}
<p style="margin-top:150pt; text-align:justify; text-indent:2em;">
  Ushbu fan sillabusi {{#if tashkilot.tashkilot_nomi}}{{tashkilot.tashkilot_nomi}}{{else}}Universitet{{/if}}
  Kengashining
  <input type="date" data-autosave-field="majlis_sanasi" value="{{formatDate sillabus.majlis_sanasi}}"
