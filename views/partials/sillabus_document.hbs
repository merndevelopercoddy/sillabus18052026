  <p{{{editableAttrs "asosiy_adabiyotlar" showInlineEdit true}}} data-placeholder="Har bir adabiyotni yangi qatordan kiriting yoki tavsiyadan tanlang..." data-suggest-target style="white-space:pre-line; min-height:24px; margin:0;">{{sillabus.asosiy_adabiyotlar}}</p>
